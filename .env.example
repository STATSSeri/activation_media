# --- Notion 読み取り（Webアプリ用インテグレーション。対象DBを共有しておく） ---
NOTION_API_TOKEN=ntn_xxxxxxxx
# 「アクティベーション事例」DBのデータソースID（ntn datasources resolve <db-id> で取得）
ACTIVATION_DATA_SOURCE_ID=xxxxxxxxxxxxxxxx

# --- ギャラリーの共有パスワード（未設定だと全ページ 503 でブロック＝誤公開防止） ---
GALLERY_PASSWORD=change-me

# --- 毎朝の Slack ダイジェスト ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# 公開URL（Slackの「ギャラリーを開く」ボタン用）。例: https://activation-media.vercel.app
GALLERY_BASE_URL=

# --- Vercel Cron 認証（Vercel が自動付与。任意の長いランダム文字列） ---
CRON_SECRET=set-a-long-random-string
